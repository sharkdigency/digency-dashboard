generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id          String   @id @default(cuid())
  agent       String
  title       String
  description String?
  status      String   @default("pending")
  client      String?
  priority    String   @default("normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  agent     String
  message   String
  type      String   @default("info")
  client    String?
  createdAt DateTime @default(now())
}
